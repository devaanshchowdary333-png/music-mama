// ── firestore.rules ──────────────────────────────────
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /movies/{movieId} {
      allow read: if true;
      allow write: if true; // No login — admin is open
    }
    match /movies/{movieId}/songs/{songId} {
      allow read: if true;
      allow write: if true;
    }
    match /{document=**} {
      allow read, write: if false;
    }
  }
}

